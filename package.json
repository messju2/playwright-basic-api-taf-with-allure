{
  "name": "playwright-api-testing",
  "version": "1.0.0",
  "description": "Playwright API Automation Framework with Allure",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf allure-results allure-report test-results",
    "test": "npx playwright test",
    "test:allure": "npm run clean && npx playwright test || true",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "allure:serve": "npx allure serve allure-results"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "allure-commandline": "^2.30.0",
    "allure-js-commons": "^3.0.0",
    "allure-playwright": "^3.10.2",
    "rimraf": "^5.0.0"
  }
}
